model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  status      Status    @default(BACKLOG)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id])
}

enum Status {
  BACKLOG
  TODO
  DONE
  DELETED
}
